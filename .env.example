APP_NAME="SVM Kassensystem"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DRIVER=single,daily,error
LOG_STACK=single
LOG_SIZE=10;MB
LOG_RETENTION_DAYS=14

DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite

FORGOT_PASSWORDS_ENABLED=false
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_TIME=60
PASSWORD_RESET_ENABLED=false
REGISTRATION_ENABLED=false

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
